<Page
    x:Class="DevOpsToolsInstaller.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="700">
            <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}" />

            <!-- Downloads folder -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Downloads Folder" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock
                        x:Name="DownloadPathText"
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        TextWrapping="Wrap"
                        IsTextSelectionEnabled="True" />
                    <Button Content="Open in Explorer" Click="OpenFolder_Click" />
                </StackPanel>
            </Border>

            <!-- Theme Settings -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="App Theme" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock
                        Text="Choose between Light, Dark, or System Default (matches Windows theme settings)."
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        TextWrapping="Wrap" />
                    <ComboBox x:Name="ThemeComboBox" Width="200" SelectionChanged="ThemeComboBox_SelectionChanged">
                        <ComboBoxItem Content="System Default" Tag="Default" />
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Storage -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Storage" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock
                        x:Name="StorageText"
                        Foreground="{ThemeResource TextSecondaryBrush}" />
                    <Button
                        x:Name="ClearButton"
                        Content="Clear Downloaded Files"
                        Click="ClearDownloads_Click" />
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="About" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Foreground="{ThemeResource TextSecondaryBrush}">
                        <Run Text="DevOps Tools Installer v1.0.0" />
                    </TextBlock>
                    <TextBlock
                        Text="A catalog-based tool downloader for DevOps engineers. Downloads official vendor installers and lets you launch them yourself."
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        TextWrapping="Wrap" />
                    <HyperlinkButton
                        Content="View on GitHub"
                        Click="GitHub_Click"
                        Foreground="{ThemeResource AccentBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

<Page
    x:Class="DevOpsToolsInstaller.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="1000">

            <!-- Header -->
            <StackPanel Spacing="2">
                <TextBlock Text="Home" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="Everything you need to set up a Windows DevOps workstation."
                           Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>

            <!-- Hero card -->
            <Border Style="{StaticResource CardStyle}" Padding="24">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            VerticalAlignment="Top">
                        <FontIcon Glyph="&#xE74C;" FontSize="26"
                                  Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="DevOps Tools Installer"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="Browse a curated catalog of official installers and CLIs, download them with live progress, and let the app take the right action for each tool." />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Safety notice -->
            <controls:InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Success"
                Title="Safe by design"
                Message="Nothing is installed silently and no scripts are auto-run. The app downloads official vendor artifacts; you decide when to run them." />

            <!-- Stats -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE8F1;" FontSize="18" HorizontalAlignment="Left"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="ToolCountText" Text="—" Style="{StaticResource MetricNumberStyle}" />
                        <TextBlock x:Name="ToolCountLabel" Text="Loading…" Style="{StaticResource MetricLabelStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE896;" FontSize="18" HorizontalAlignment="Left"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="DownloadedCountText" Text="0" Style="{StaticResource MetricNumberStyle}" />
                        <TextBlock x:Name="DownloadedCountLabel" Text="Downloaded" Style="{StaticResource MetricLabelStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick links -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Quick links" Style="{StaticResource CardTitleStyle}" />

                    <Button Style="{StaticResource QuickLinkButtonStyle}" Click="Catalog_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE8F1;" FontSize="16" />
                            <StackPanel>
                                <TextBlock Text="Browse Tool Catalog" FontWeight="SemiBold" />
                                <TextBlock Text="Search and select tools to download"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource QuickLinkButtonStyle}" Click="Downloads_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE896;" FontSize="16" />
                            <StackPanel>
                                <TextBlock Text="View Downloads" FontWeight="SemiBold" />
                                <TextBlock Text="Track progress and run installers"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- How it works -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="How it works" Style="{StaticResource CardTitleStyle}" />

                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}">
                                <TextBlock Text="1" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Browse the catalog grouped by category." />
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}">
                                <TextBlock Text="2" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Select the tools you need and download them concurrently." />
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}">
                                <TextBlock Text="3" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Install, extract, or add to your tools folder — the right action per tool." />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

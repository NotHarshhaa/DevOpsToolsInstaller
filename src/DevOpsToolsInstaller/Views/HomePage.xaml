<Page
    x:Class="DevOpsToolsInstaller.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="24" MaxWidth="900">
            <TextBlock Text="Home" Style="{StaticResource PageTitleStyle}" />

            <!-- Welcome banner -->
            <Border Background="{ThemeResource WelcomeBannerBrush}" BorderThickness="0" CornerRadius="12" MinHeight="180" Padding="32,24">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <FontIcon Glyph="&#xE74C;" FontSize="48" Foreground="#FFFFFF" />
                    <TextBlock
                        Text="DevOps Tools Installer"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="#FFFFFF"
                        TextAlignment="Center" />
                    <TextBlock
                        Text="Browse the catalog, download official installers, and launch them — all from one place. No silent installs, no scripts, no admin required."
                        Foreground="#F0F0F0"
                        TextAlignment="Center"
                        TextWrapping="Wrap"
                        MaxWidth="550" />
                </StackPanel>
            </Border>

            <!-- Stats + Quick links row -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Stats card -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Catalog Summary" Style="{StaticResource CardTitleStyle}" />
                        <Grid ColumnSpacing="16" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <Border Background="{ThemeResource BadgeBackgroundBrush}" CornerRadius="8" Padding="12">
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="ToolCountText" Text="-" Style="{StaticResource MetricNumberStyle}" />
                                        <TextBlock x:Name="ToolCountLabel" Text="Loading..." Style="{StaticResource MetricLabelStyle}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <Border Background="{ThemeResource BadgeBackgroundBrush}" CornerRadius="8" Padding="12">
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="DownloadedCountText" Text="0" Style="{StaticResource MetricNumberStyle}" Foreground="{ThemeResource SuccessBrush}" />
                                        <TextBlock x:Name="DownloadedCountLabel" Text="Downloaded" Style="{StaticResource MetricLabelStyle}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Quick links card -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Quick Links" Style="{StaticResource CardTitleStyle}" />
                        <Button Content="Browse Tool Catalog" Style="{StaticResource QuickLinkButtonStyle}" Click="Catalog_Click" />
                        <Button Content="View Downloads" Style="{StaticResource QuickLinkButtonStyle}" Click="Downloads_Click" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- How it works card -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="How it works" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="1. Browse the catalog grouped by category" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock Text="2. Select the tools you need and click Download" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock Text="3. Watch real-time progress for each download" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock Text="4. Install, extract, or add to your tools folder — the right action per tool" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock
                        Text="Your app never installs anything silently. The vendor installer handles everything, including its own UAC prompt."
                        Foreground="{ThemeResource TextMutedBrush}"
                        FontStyle="Italic"
                        TextWrapping="Wrap"
                        Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

<Page
    x:Class="DevOpsToolsInstaller.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="24" MaxWidth="900">
            <TextBlock Text="Home" Style="{StaticResource PageTitleStyle}" />

            <!-- Welcome banner -->
            <Border Style="{StaticResource CardStyle}" MinHeight="160">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <FontIcon Glyph="&#xE74C;" FontSize="48" Foreground="{ThemeResource AccentBrush}" />
                    <TextBlock
                        Text="DevOps Tools Installer"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        TextAlignment="Center" />
                    <TextBlock
                        Text="Browse the catalog, download official installers, and launch them — all from one place. No silent installs, no scripts, no admin required."
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        TextAlignment="Center"
                        TextWrapping="Wrap"
                        MaxWidth="500" />
                </StackPanel>
            </Border>

            <!-- Stats + Quick links row -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Stats card -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Catalog" Style="{StaticResource CardTitleStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8F1;" FontSize="16" Foreground="{ThemeResource AccentBrush}" />
                            <TextBlock x:Name="ToolCountText" Text="Loading..." Foreground="{ThemeResource TextSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE896;" FontSize="16" Foreground="{ThemeResource SuccessBrush}" />
                            <TextBlock x:Name="DownloadedCountText" Text="0 downloaded" Foreground="{ThemeResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Quick links card -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Quick Links" Style="{StaticResource CardTitleStyle}" />
                        <Button Content="Browse Tool Catalog" Style="{StaticResource QuickLinkButtonStyle}" Click="Catalog_Click" />
                        <Button Content="View Downloads" Style="{StaticResource QuickLinkButtonStyle}" Click="Downloads_Click" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- How it works card -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="How it works" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="1. Browse the catalog grouped by category" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock Text="2. Select the tools you need and click Download" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock Text="3. Watch real-time progress for each download" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock Text="4. Click Run Installer to launch the vendor's official setup" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <TextBlock
                        Text="Your app never installs anything silently. The vendor installer handles everything, including its own UAC prompt."
                        Foreground="{ThemeResource TextMutedBrush}"
                        FontStyle="Italic"
                        TextWrapping="Wrap"
                        Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

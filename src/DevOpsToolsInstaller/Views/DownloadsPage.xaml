<Page
    x:Class="DevOpsToolsInstaller.Views.DownloadsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DevOpsToolsInstaller.Models">

    <Grid Padding="32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Downloads" Style="{StaticResource PageTitleStyle}" />

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Open Downloads Folder" Click="OpenFolder_Click" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextSecondaryBrush}" Margin="12,0,0,0" />
        </StackPanel>

        <!-- Download list -->
        <ListView
            x:Name="DownloadsList"
            Grid.Row="2"
            SelectionMode="None"
            IsItemClickEnabled="False">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Tool name -->
                        <TextBlock
                            Grid.Column="0"
                            Text="{Binding Name}"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            VerticalAlignment="Center"
                            MinWidth="180" />

                        <!-- Progress bar -->
                        <ProgressBar
                            Grid.Column="1"
                            Value="{Binding Progress, Mode=OneWay}"
                            Maximum="100"
                            VerticalAlignment="Center"
                            Height="8"
                            CornerRadius="4" />

                        <!-- Status text -->
                        <TextBlock
                            Grid.Column="2"
                            Text="{Binding StatusText, Mode=OneWay}"
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            VerticalAlignment="Center" />

                        <!-- Percentage -->
                        <TextBlock
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextMutedBrush}"
                            FontSize="12"
                            MinWidth="50"
                            Text="{Binding StatusText, Mode=OneWay}" />

                        <!-- Run installer button -->
                        <Button
                            Grid.Column="4"
                            Content="Run Installer"
                            Click="RunInstaller_Click"
                            IsEnabled="{Binding IsDownloaded, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="12,6"
                            FontSize="12" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state -->
        <StackPanel
            x:Name="EmptyState"
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12"
            Visibility="Collapsed">
            <FontIcon Glyph="&#xE896;" FontSize="48" Foreground="{ThemeResource TextMutedBrush}" />
            <TextBlock
                Text="No downloads yet"
                FontSize="16"
                Foreground="{ThemeResource TextSecondaryBrush}"
                TextAlignment="Center" />
            <TextBlock
                Text="Go to Tool Catalog to select and download tools."
                Foreground="{ThemeResource TextMutedBrush}"
                TextAlignment="Center" />
            <Button Content="Browse Catalog" Style="{StaticResource AccentButtonStyle}"
                    Click="GoToCatalog_Click" Margin="0,8,0,0" />
        </StackPanel>
    </Grid>
</Page>

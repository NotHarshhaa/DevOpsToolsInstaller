<Page
    x:Class="DevOpsToolsInstaller.Views.CatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DevOpsToolsInstaller.Models">

    <Grid Padding="32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Tool Catalog" Style="{StaticResource PageTitleStyle}" />

        <!-- Toolbar -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <Button x:Name="SelectAllButton" Content="Select All" Click="SelectAll_Click" />
                <Button x:Name="ClearButton" Content="Clear" Click="Clear_Click" />
                <Button x:Name="DownloadButton" Content="Download Selected"
                        Style="{StaticResource AccentButtonStyle}" Click="Download_Click" />
                <ProgressRing x:Name="BusyRing" Width="24" Height="24" Visibility="Collapsed" />
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextSecondaryBrush}" />
            </StackPanel>

            <AutoSuggestBox
                Grid.Column="1"
                x:Name="SearchBox"
                PlaceholderText="Search tools..."
                QueryIcon="Find"
                Width="220"
                TextChanged="SearchBox_TextChanged" />
        </Grid>

        <!-- Tool list -->
        <ListView
            x:Name="ToolsList"
            Grid.Row="2"
            SelectionMode="None"
            IsItemClickEnabled="False">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ListViewCardStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <CheckBox
                                Grid.Column="0"
                                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                MinWidth="0"
                                VerticalAlignment="Center" />

                            <FontIcon
                                Grid.Column="1"
                                Glyph="{Binding IconGlyph}"
                                FontSize="22"
                                Foreground="{ThemeResource AccentBrush}"
                                VerticalAlignment="Center" />

                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center" Margin="4,0,0,0">
                                <TextBlock
                                    Text="{Binding NameWithVersion}"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextPrimaryBrush}"
                                    FontSize="15" />
                                <TextBlock
                                    Text="{Binding Description}"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextSecondaryBrush}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Border Background="{ThemeResource BadgeBackgroundBrush}"
                                        CornerRadius="6"
                                        Padding="10,5">
                                    <TextBlock
                                        Text="{Binding KindLabel}"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AccentBrush}" />
                                </Border>
                                <Border Background="{ThemeResource BadgeBackgroundBrush}"
                                        CornerRadius="6"
                                        Padding="10,5">
                                    <TextBlock
                                        Text="{Binding Category}"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextMutedBrush}" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

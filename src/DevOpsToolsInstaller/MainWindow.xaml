<Window
    x:Class="DevOpsToolsInstaller.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <!-- No Background set: the Mica backdrop shows through. -->
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar (transparent so Mica shows through) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="10">
                <FontIcon Glyph="&#xE74C;" FontSize="16" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock
                    Text="DevOps Tools Installer"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    FontWeight="SemiBold"
                    FontSize="13"
                    VerticalAlignment="Center" />
                <Border Style="{StaticResource BadgeStyle}" Padding="8,1" Margin="4,0,0,0">
                    <TextBlock Text="v1.1.0" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Border>
            </StackPanel>
        </Grid>

        <!-- Navigation + content -->
        <controls:NavigationView
            x:Name="NavView"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="True"
            SelectionChanged="NavView_SelectionChanged"
            OpenPaneLength="240">

            <controls:NavigationView.MenuItems>
                <controls:NavigationViewItem Content="Home" Tag="Home">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </controls:NavigationViewItem.Icon>
                </controls:NavigationViewItem>
                <controls:NavigationViewItem Content="Tool Catalog" Tag="Catalog">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" />
                    </controls:NavigationViewItem.Icon>
                </controls:NavigationViewItem>
                <controls:NavigationViewItem Content="Downloads" Tag="Downloads">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE896;" />
                    </controls:NavigationViewItem.Icon>
                </controls:NavigationViewItem>
            </controls:NavigationView.MenuItems>

            <controls:NavigationView.FooterMenuItems>
                <controls:NavigationViewItem Content="Settings" Tag="Settings">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </controls:NavigationViewItem.Icon>
                </controls:NavigationViewItem>
            </controls:NavigationView.FooterMenuItems>

            <!-- Content host: a rounded, layered surface over the Mica backdrop -->
            <Border
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,1,0,0"
                CornerRadius="8,0,0,0"
                Margin="0,0,0,0">
                <Frame x:Name="ContentFrame" Background="Transparent" />
            </Border>
        </controls:NavigationView>
    </Grid>
</Window>
